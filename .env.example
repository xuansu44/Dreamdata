# dreamdata environment template — copy to .env and fill in
DATABASE_URL=postgresql://user:password@localhost:5432/dreamdata
WORKSPACE_PATH=/absolute/path/to/dreamdata_workspace
USER_ID=your_name

# Optional
# DUCKDB_MEMORY_LIMIT=4GB
# DUCKDB_THREADS=4
# LOG_LEVEL=INFO
# TAG_VALUE_MAX_BYTES=4096
# NOTE_VALUE_MAX_BYTES=65536
